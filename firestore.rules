rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isStoreOwner(storeId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/stores/$(storeId)) && 
             get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    function isChatParticipant(chatId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/chats/$(chatId)) && 
             request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isAdmin() {
      return isAuthenticated() && 
             ((request.auth.token.email == "saad1998ahmedgg@gmail.com" && request.auth.token.email_verified == true) ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == 'admin'));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'type']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['buyer', 'seller', 'admin'];
    }

    function isValidStore(data) {
      let requiredFields = ['ownerId', 'name', 'description', 'logoUrl', 'coverUrl'];
      let optionalFields = ['ownerName', 'ownerAvatar', 'coverImage', 'images', 'phone', 'location', 'city', 'followers', 'shippingPolicy', 'featuredProductIds', 'views'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 2000 &&
             (!('ownerName' in data) || (data.ownerName is string && data.ownerName.size() < 100)) &&
             (!('ownerAvatar' in data) || (data.ownerAvatar is string && data.ownerAvatar.size() < 2000));
    }

    function isValidProduct(data) {
      let requiredFields = ['storeId', 'name', 'price', 'description', 'images'];
      let optionalFields = ['imageUrl', 'productImage', 'image', 'picture', 'category', 'reviews'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() < 5000 &&
             data.images is list && data.images.size() <= 10;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['buyerId', 'storeId', 'items', 'total', 'status', 'date']) &&
             data.buyerId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['new', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['sellerId', 'status', 'renewalDate']) &&
             data.sellerId == request.auth.uid &&
             data.status in ['active', 'inactive'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'message', 'date', 'read']) &&
             data.type in ['order', 'review', 'system'] &&
             data.title is string && data.title.size() < 200 &&
             data.message is string && data.message.size() < 1000 &&
             data.read is bool;
    }

    function isValidChat(data) {
      let requiredFields = ['participants'];
      let optionalFields = ['participantNames', 'participantAvatars', 'lastMessage', 'storeId'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields.concat(optionalFields)) &&
             data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'text', 'timestamp', 'read']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.read is bool;
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['storeId', 'name', 'type', 'discountType', 'value', 'startDate', 'endDate', 'isFollowersOnly', 'isActive']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['discount', 'coupon'] &&
             data.discountType in ['percentage', 'fixed'] &&
             data.value is number && data.value > 0 &&
             data.isActive is bool;
    }

    function isValidStar(data) {
      return data.keys().hasAll(['imageUrl', 'createdAt']) &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 2000 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow create: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.type != 'admin') || isAdmin();
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.type == resource.data.type) || isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if (isAuthenticated() && isValidStore(request.resource.data)) || isAdmin();
      allow update: if isAdmin() || 
                    (isAuthenticated() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId) ||
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers'])) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated(); // Allow any authenticated user to create
      allow update: if isAuthenticated(); // Allow any authenticated user to update
      allow delete: if isAuthenticated(); // Allow any authenticated user to delete
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || isStoreOwner(resource.data.storeId) || isAdmin());
      allow create: if (isAuthenticated() && isValidOrder(request.resource.data)) || isAdmin();
      allow update: if (isAuthenticated() && (
        (resource.data.buyerId == request.auth.uid && request.resource.data.status == 'cancelled') || 
        isStoreOwner(resource.data.storeId)
      ) && request.resource.data.buyerId == resource.data.buyerId && request.resource.data.storeId == resource.data.storeId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && isValidSubscription(request.resource.data)) || isAdmin();
      allow update: if (isAuthenticated() && resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && isValidNotification(request.resource.data)) || isAdmin();
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && isValidChat(request.resource.data)) || isAdmin();
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if (isAuthenticated() && isChatParticipant(request.resource.data.chatId) && isValidMessage(request.resource.data)) || isAdmin();
      allow update: if (isAuthenticated() && isChatParticipant(resource.data.chatId) && request.resource.data.senderId == resource.data.senderId && request.resource.data.chatId == resource.data.chatId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if (isAuthenticated() && isStoreOwner(request.resource.data.storeId) && isValidOffer(request.resource.data)) || isAdmin();
      allow update: if (isAuthenticated() && isStoreOwner(resource.data.storeId) && request.resource.data.storeId == resource.data.storeId) || isAdmin();
      allow delete: if (isAuthenticated() && isStoreOwner(resource.data.storeId)) || isAdmin();
    }

    match /stars/{starId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStar(request.resource.data);
      allow update: if false;
      allow delete: if isAuthenticated();
    }
  }
}
